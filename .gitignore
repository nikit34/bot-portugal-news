.idea/
.vscode/
venv/
.venv/

secret

# Telethon session files are credentials — never commit them. CI auth uses the
# TELEGRAM_SESSION secret (StringSession); local dev uses the on-disk file.
*.session
bot.session-journal
getter_bot.session-journal

# Learning state — persisted across CI runs via actions/cache (fast path) AND
# committed back to the repo (durable backstop, survives cache eviction). Ignore
# the dir but keep the single committed state file tracked.
state/*
!state/insights_state.json

# Runtime logs written by the logger.
logs/

**/__pycache__/
